# Public dependencies resolve from the default npm registry.
registry=https://registry.npmjs.org/

# Only the @offload-project scope is hosted on GitHub Packages (publish target
# and where this package's own scope is fetched from). This keeps public
# transitive deps (e.g. valibot) from being requested off GitHub Packages.
@offload-project:registry=https://npm.pkg.github.com/
